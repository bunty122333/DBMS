select item_id,quantity*unit_price as total_price
from orderitems
where order_id=1;
select distinct c.name
from customers c, orders o
where c.customer_id=o.customer_id;
select count(*) as total_customers
from customers;
select item_name
from menu
where item_id not in
select item_id from orderitems;
select item_name
from menu
where item_id not in
(select item_id from orderitems);
select c.name
from customers c, orders o, orderitems oi, menu m
where c.customer_id=o.customer_id
m.category in ('pizza','burgers')
having count(distinct m.category)=2;
select c.name
from customers c, orders o, orderitems oi, menu m
where c.customer_id=o.customer_id
m.category in ('pizza','burgers')
group by c.name
having count(distinct m.category)=2;
select c.name
from customers c, orders o, orderitems oi, menu m
where c.customer_id=o.customer_id
and o.order_id=oi.order_id
and oi.item_id=m.item_id
and m.category in ('pizza','burgers')
group by c.name
having count(distinct m.category)=2;
