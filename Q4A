create view stock as
select p.name,sum(i.quantity_in_stock) as total_stock
from products p, inventory i
where p.product_id=i.product_id
having sum(i.quantity_in_stock)<10;
create view low_stock as
select p.name,sum(i.quantity_in_stock) as total_stock
from products p, inventory i
where p.product_id=i.product_id
having sum(i.quantity_in_stock)<10;
create view low_stock as
